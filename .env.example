VITE_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx"
VITE_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# TossPayments (https://docs.tosspayments.com)
# CLIENT key is safe to ship in the bundle (publishable).
#   - dev:  test_ck_xxx
#   - prod: live_ck_xxx
# If left unset, the app falls back to Toss's public test key, so payments
# render but are not chargeable to a real merchant.
VITE_PUBLIC_TOSS_CLIENT_KEY="test_ck_xxxxxxxxxxxxxxxxxxxxxxxx"

# ── Supabase Edge Function secrets (set via `supabase secrets set ...`) ──
# These are NOT used by Vite/the browser — listed here for reference only.
#
# TOSS_SECRET_KEY="test_sk_xxx"        # SECRET key, server-only. Live = live_sk_xxx
# TOSS_WEBHOOK_SECRET="<random-32b>"   # Shared secret in X-Toss-Webhook-Secret header
